# ============================================================
# LastEpochTools .gitignore
# Windows PC: extraction machine
# MacBook: consumes exports_json/ from git
# ============================================================

# --- Game files (gigabytes, stays on Windows only) ---
game_files/

# --- Raw bundle data (18,000+ files, regeneratable) ---
extracted_raw/raw_bundles/

# --- Large binary caches (regenerated by pipeline) ---
extracted_raw/MasterAffixesList.json
extracted_raw/MasterItemsList.json
extracted_raw/UniqueList.json

# --- IL2CPP dummy DLLs (large, regeneratable from GameAssembly.dll) ---
il2cpp_dump/DummyDll/
il2cpp_dump/il2cpp.h

# --- Python cache ---
tools/scripts/__pycache__/
**/__pycache__/
*.pyc
*.pyo

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor ---
.vscode/
*.suo
*.user

# ============================================================
# WHAT IS COMMITTED (everything not listed above):
#   exports_json/          ← processed game data JSONs (Mac's data source)
#   extracted_raw/enums/   ← enum definitions
#   extracted_raw/manifest.json
#   extracted_raw/AffixImport.csv
#   extracted_raw/community_skilltrees.ts
#   extracted_raw/ggm_monoscripts.json
#   extracted_raw/resources_manifest.json
#   extracted_raw/MonolithTimelines.json
#   tools/scripts/*.py     ← Python pipeline
#   il2cpp_dump/script.json
#   il2cpp_dump/stringliteral.json
#   assetstudio_search_guide.md
#   game_data_extraction_pipeline.md
#   patch_versions/        ← version snapshots (DLL + metadata only)
# ============================================================
