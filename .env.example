# =============================================================================
# The Forge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For production, use .env.production with docker-compose.prod.yml.
# NEVER commit .env files with real secrets to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://forge:forgedev@127.0.0.1:5432/the_forge
DB_PASSWORD=forgedev

# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------
SECRET_KEY=change-this-in-production
FLASK_ENV=development

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# ---------------------------------------------------------------------------
# Discord OAuth2
# Create app at https://discord.com/developers/applications
# ---------------------------------------------------------------------------
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=http://localhost:5050/api/auth/discord/authorized

# Discord webhook URL for import failure alerts.
# Get from Discord channel settings > Integrations > Webhooks.
# Leave empty to disable alerts (failures are still logged to DB).
DISCORD_IMPORT_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Redis (rate limiting + cache)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Game data
# ---------------------------------------------------------------------------
DATA_VERSION=1.0.0
CURRENT_PATCH=1.4.3
CURRENT_SEASON=4

# ---------------------------------------------------------------------------
# Production-only (used by docker-compose.prod.yml)
# ---------------------------------------------------------------------------
# APP_VERSION=0.8.0
# HOST_PORT=80
# GUNICORN_WORKERS=4
# GUNICORN_THREADS=2
