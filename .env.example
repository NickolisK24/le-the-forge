# Database (port 5432 for native install; Docker maps to 5433, override if needed)
DATABASE_URL=postgresql://forge:forgedev@127.0.0.1:5432/the_forge
DB_PASSWORD=forgedev

# Flask
SECRET_KEY=change-this-in-production
FLASK_ENV=development

# Discord OAuth2
# Create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=change-this
DISCORD_CLIENT_SECRET=change-this-too
DISCORD_REDIRECT_URI=http://localhost:5050/api/auth/discord/callback

# Redis (used for rate limiting + session cache)
REDIS_URL=redis://localhost:6379/0

# Frontend
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET_KEY=change-this-too
JWT_ACCESS_TOKEN_EXPIRES=3600

# Game data
DATA_VERSION=1.0.0
CURRENT_PATCH=1.2

# Discord webhook URL for import failure alerts.
# Get from Discord channel settings > Integrations > Webhooks.
# Leave empty to disable alerts (failures are still logged to DB).
DISCORD_IMPORT_WEBHOOK_URL=
